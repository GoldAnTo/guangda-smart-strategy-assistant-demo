  "aiInterpretationPrompts": {
    "system": "你是一位专业、资深的私募资产管理顾问。你对光大资管的每一条策略产品都有深入了解，擅长用通俗易懂的语言向客户解释策略特点、风险收益特征和适用场景。",
    "matchReasonTemplate": "根据您刚才提供的信息（{profile_summary}），{strategy_name}在这个场景下值得优先关注，原因如下：{reasons}。需要留意的是：{cautions}。",
    "comparisonTemplate": "以下{count}条策略在您的需求下进行了初步筛选，逐条说明差异：{comparisons}",
    "nextQuestionTemplate": "为了给您更精准的建议，还需要了解：{questions}"
  },

  "escalationRules": [
    {
      "condition": "investment_amount > 1000",
      "escalationType": "large_account",
      "shouldEscalate": true,
      "reason": "投资金额较大，建议转专业客户经理一对一服务"
    },
    {
      "condition": "customer_age < 25 OR customer_age > 65",
      "escalationType": "age_sensitive",
      "shouldEscalate": true,
      "reason": "该年龄段客户需要更详细的风险适配评估"
    },
    {
      "condition": "risk_level == 'conservative' AND return_expectation IN ['growth', 'absolute_return']",
      "escalationType": "mismatch",
      "shouldEscalate": true,
      "reason": "您的风险偏好与收益目标存在较大差异，建议进一步沟通"
    }
  ],

  "complianceRules": [
    {
      "ruleId": "C-001",
      "forbiddenPhrases": ["保本", "稳赚", "确定收益", "不会亏", "零风险", "本金无忧"],
      "replaceHint": "请改为'追求稳健增值'、'力争获取较好回报'、'历史表现不代表未来'等合规表达"
    },
    {
      "ruleId": "C-002",
      "forbiddenPhrases": ["保证", "承诺", "一定"],
      "replaceHint": "请删除绝对化表述"
    }
  ]
